using Microsoft.EntityFrameworkCore;
using NKZAPI.Data;
using NKZAPI.Models;

namespace NKZAPI.Repositories
{
    public class TeamRepository
    {
        private readonly NKZAPIContext _context;
        public TeamRepository(NKZAPIContext context)
        {
            _context = context;
        }

        public async Task<List<Team>> GetAllTeamsAsync()
        {
            return await _context.Teams
                .Include(t => t.Captains)
                .Include(t => t.Players)
                .ToListAsync();
        }
        public async Task<Team?> GetTeamByIdAsync(Guid id)
        {
            return await _context.Teams
                .Include(t => t.Captains)
                .Include(t => t.Players)
                .FirstOrDefaultAsync(t => t.Id == id);
        }
        public async Task<Team> AddTeamAsync(Team team)
        {
            var Return = await _context.Teams.AddAsync(team);
            await _context.SaveChangesAsync();
            return Return.Entity;
        }
        public async Task<Team> UpdateTeamAsync(Team team)
        {
            var Return = _context.Teams.Update(team);
            await _context.SaveChangesAsync();
            return Return.Entity;
        }
        public async Task DeleteTeamAsync(Team team)
        {
            _context.Teams.Remove(team);
            await _context.SaveChangesAsync();
        }
    }
}
